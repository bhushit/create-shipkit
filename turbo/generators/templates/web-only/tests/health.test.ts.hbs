import { app } from "@/app/router";
import { describe, expect, it } from "vitest";

describe("Health endpoint", () => {
  it("returns ok", async () => {
    const res = await app.request("/health");
    expect(res.status).toBe(200);
    const body = await res.json();
    expect(body.status).toBe("ok");
  });
});

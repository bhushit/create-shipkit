name: Preview Update

# Pushes a JS bundle via EAS Update for every PR.
# Uses the "preview" channel. Reviewers scan the QR with a dev client build.
#
# Native changes (ios/, android/, app.config.ts, native deps) need an EAS Build
# instead - see native-build.yml.

on:
  pull_request:
    branches: [main]
    paths-ignore:
      - "ios/**"
      - "android/**"
      - "app.config.ts"
      - "app.json"

jobs:
  update:
    runs-on: ubuntu-latest
    permissions:
      contents: read
      pull-requests: write
    steps:
      - uses: actions/checkout@v4
      - uses: pnpm/action-setup@v4
      - uses: actions/setup-node@v4
        with:
          node-version-file: ".nvmrc"
          cache: "pnpm"
      - uses: expo/expo-github-action@v8
        with:
          eas-version: latest
          token: <% secrets.EXPO_TOKEN %>
      - run: pnpm install --frozen-lockfile
      - name: Publish preview update
        id: update
        run: |
          eas update --auto --branch=pr-<% github.event.pull_request.number %> --non-interactive
          ACCOUNT=$(grep 'owner:' app.config.ts | sed 's/.*"\(.*\)".*/\1/')
          echo "branch_url=https://expo.dev/accounts/$ACCOUNT/projects/{{name}}/branches/pr-<% github.event.pull_request.number %>" >> $GITHUB_OUTPUT
      - name: Comment preview link
        uses: marocchino/sticky-pull-request-comment@v2
        with:
          header: preview
          message: |
            📱 **Preview update published** — branch `pr-<% github.event.pull_request.number %>`

            **On your phone:**
            1. Open your dev client build (needs `expo-updates` + `developmentClient: true` profile)
            2. Scan the QR at: <% steps.update.outputs.branch_url %>

            **First time?** Install the dev client:
            ```
            eas build --profile development --platform ios
            ```
